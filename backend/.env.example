# ──────────────────────────────────────────────
# Omni_CortexX — Environment Variables
# Copy this to .env and fill in your keys
# ──────────────────────────────────────────────

# --- Gemini (OCR Only) ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- Featherless AI (All Agent Reasoning) ---
# Comma-separated keys for round-robin. Budget per key = 4.
# Heavy models (Kimi, Qwen-72B) cost 4; light models (gemma, Qwen3-32B) cost 2.
FEATHERLESS_API_KEY=key1-here,key2-here,key3-here,key4-here
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1/chat/completions
FEATHERLESS_BUDGET_PER_KEY=4

# --- Research Tools ---
TAVILY_API_KEY=your-tavily-api-key-here
GOOGLE_CSE_API_KEY=your-google-cse-api-key-here
GOOGLE_CSE_CX=your-google-cse-cx-here

# --- Application ---
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
MAX_DEBATE_ROUNDS=5
CONSENSUS_THRESHOLD=0.85

# --- Optional Redis Caching ---
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
